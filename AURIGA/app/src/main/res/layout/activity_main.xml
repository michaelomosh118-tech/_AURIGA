<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/space_black">

    <!-- 1. FULL SCREEN CAMERA PREVIEW -->
    <TextureView
        android:id="@+id/camera_preview"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- 2. GRID / SCANLINE OVERLAY (Aesthetic) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.05"
        android:background="@drawable/hud_grid_overlay" />

    <!-- 3. TOP HUD: STATUS & MODE -->
    <!--
        system_status is declared FIRST so that mode_label can reference
        its id in layout_toStartOf without forward-declaration fragility
        on older Android versions. Both TextViews inherit width/height
        wrap_content from HUDLabelSmall; mode_label overrides width to
        0dp + ellipsize so long product names ("AURIGANAVI // SPATIAL
        ENGINE") cannot visually overlap the right-anchored status text
        on narrow screens (observed on Galaxy A07 @ 720px preview).
    -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/system_status"
            style="@style/HUDLabelSmall"
            android:layout_alignParentEnd="true"
            android:text="ONLINE // 60FPS" />

        <TextView
            android:id="@+id/mode_label"
            style="@style/HUDLabelSmall"
            android:layout_width="0dp"
            android:layout_toStartOf="@id/system_status"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:singleLine="true"
            android:text="AURIGANAVI // NAVIGATION MODE" />
    </RelativeLayout>

    <!-- 4. CENTER HUD: RADAR SWEEP -->
    <View
        android:id="@+id/radar_sweep"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_centerInParent="true"
        android:alpha="0.2"
        android:background="@drawable/radar_circle_anim" />

    <!-- 5. LEFT HUD: DISTANCE READOUT -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentLeft="true"
        android:layout_centerVertical="true"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            style="@style/HUDLabelSmall"
            android:text="DISTANCE" />

        <TextView
            android:id="@+id/distance_readout"
            style="@style/HUDReadoutLarge"
            android:text="0.0m" />
    </LinearLayout>

    <!-- 6. RIGHT HUD: BEARING READOUT -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentRight="true"
        android:layout_centerVertical="true"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            style="@style/HUDLabelSmall"
            android:layout_gravity="right"
            android:text="BEARING" />

        <TextView
            android:id="@+id/bearing_readout"
            style="@style/HUDReadoutLarge"
            android:layout_gravity="right"
            android:text="0°" />
    </LinearLayout>

    <!-- 7. BOTTOM HUD: SIGNATURE TAG -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:padding="24dp">

        <TextView
            android:id="@+id/object_signature"
            style="@style/HUDReadoutLarge"
            android:layout_centerHorizontal="true"
            android:text="SCANNING..."
            android:textSize="32sp" />
    </RelativeLayout>

    <!--
        9. DIAGNOSTIC OVERLAY (long-press AURIGA NAVI title to toggle).
        Kept gone by default so the HUD stays clean for end users;
        devs running the jitter-diagnosis pass see raw LUT rows, pitch
        radians, GhostAnchor shift magnitude, detection confidence,
        sanity score, active bitmap size, and whether a trained
        profile is loaded. Monospace so values line up frame to frame
        and the eye picks out which column is flickering.
    -->
    <TextView
        android:id="@+id/diagnostic_overlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="72dp"
        android:layout_marginEnd="12dp"
        android:background="#CC000000"
        android:padding="8dp"
        android:fontFamily="monospace"
        android:textColor="#B2FFE6"
        android:textSize="10sp"
        android:text=""
        android:visibility="gone"
        android:contentDescription="Auriga diagnostic overlay" />

    <!-- 8. ALERT HUD: SKYSHIELD™ OVERHANG BANNER -->
    <TextView
        android:id="@+id/alert_banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:background="@color/alert_red"
        android:gravity="center"
        android:padding="12dp"
        android:text="⚠ OVERHANG DETECTED"
        android:textColor="@color/hud_text"
        android:textSize="20sp"
        android:textStyle="bold"
        android:visibility="gone" />

</RelativeLayout>
