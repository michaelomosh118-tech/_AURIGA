<?xml version="1.0" encoding="utf-8"?>
<!--
    Object Targets picker. Themed to match the AurigaNavi HUD: deep-space
    background, cyan accents, glassy headers. The category chips are
    inflated dynamically by TargetsActivity into targets_chip_container so
    keeping the labels in one place (TargetStore.CATEGORIES) keeps the UI
    in lockstep with the matching code.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/deep_space"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="40dp"
        android:paddingBottom="32dp">

        <!-- Eyebrow -->
        <TextView
            style="@style/HUDLabelSmall"
            android:textColor="@color/muted_label"
            android:text="DrakoSanctis // Tools" />

        <!-- Title -->
        <TextView
            android:id="@+id/targets_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="OBJECT TARGETS"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/flavor_accent"
            android:fontFamily="sans-serif-condensed"
            android:letterSpacing="0.14"
            android:shadowColor="@color/flavor_accent"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="14" />

        <!-- Subtitle / honest copy about offline trade-off -->
        <TextView
            android:id="@+id/targets_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textSize="13sp"
            android:textColor="@color/muted_label"
            android:lineSpacingExtra="3sp"
            android:text="" />

        <!-- ANY OBJECT wildcard chip lives outside the dynamic chip
             container so it can sit above its own divider. -->
        <Button
            android:id="@+id/targets_any_chip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:minHeight="52dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:gravity="start|center_vertical"
            android:textAllCaps="true"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.06"
            android:background="@drawable/target_chip_bg"
            android:textColor="#9FE9FF"
            android:text="ANY OBJECT  ·  match every detection" />

        <!-- Section header for individual categories -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/targets_section_categories"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ML KIT CATEGORIES"
                android:textSize="10sp"
                android:textColor="@color/flavor_accent"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.22"
                android:textAllCaps="true"
                android:shadowColor="@color/flavor_accent"
                android:shadowRadius="6"
                android:shadowDx="0"
                android:shadowDy="0" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:background="@drawable/drawer_section_divider" />
        </LinearLayout>

        <!-- Dynamic chips. TargetsActivity inflates one button per
             TargetStore.CATEGORIES entry. -->
        <LinearLayout
            android:id="@+id/targets_chip_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <!-- Action row: clear + done -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="32dp">

            <Button
                android:id="@+id/targets_clear"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="10dp"
                android:minHeight="52dp"
                android:background="@drawable/target_chip_bg"
                android:textAllCaps="true"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.12"
                android:textColor="#9FE9FF"
                android:text="CLEAR ALL" />

            <Button
                android:id="@+id/targets_done"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="52dp"
                android:background="@drawable/target_chip_selected_bg"
                android:textAllCaps="true"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.12"
                android:textColor="#001A1F"
                android:text="DONE" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
