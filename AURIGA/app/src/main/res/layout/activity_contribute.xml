<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/deep_space"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Top bar -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="16dp"
            android:paddingBottom="20dp">

            <Button
                android:id="@+id/contribute_back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:background="@drawable/diag_toggle_bg"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:minHeight="44dp"
                android:text="←"
                android:textSize="18sp"
                android:textColor="@color/auriga_cyan"
                android:contentDescription="Back" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CONTRIBUTE"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/emerald_green"
                    android:fontFamily="sans-serif-condensed"
                    android:letterSpacing="0.14"
                    android:textAllCaps="true"
                    android:shadowColor="@color/emerald_green"
                    android:shadowRadius="12"
                    android:shadowDx="0"
                    android:shadowDy="0" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DrakoSanctis // Auriga"
                    android:textSize="11sp"
                    android:textColor="@color/muted_label"
                    android:fontFamily="sans-serif"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </RelativeLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@drawable/drawer_section_divider"
            android:layout_marginBottom="16dp" />

        <!-- Intro -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/drawer_item_contribute_bg"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⊛  YOU MAKE AURIGA BETTER"
                android:textSize="10sp"
                android:textColor="@color/emerald_green"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.18"
                android:textAllCaps="true"
                android:layout_marginBottom="8dp" />

            <TextView
                style="@style/DocBody"
                android:textSize="13sp"
                android:text="Every calibration profile submitted, every bug filed, and every SDK partner that integrates Auriga extends spatial intelligence to a new set of eyes. Thank you for being part of the ecosystem." />
        </LinearLayout>

        <!-- Calibration Profile section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CALIBRATION PROFILE"
            android:textSize="10sp"
            android:textColor="@color/emerald_green"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.22"
            android:textAllCaps="true"
            android:shadowColor="@color/emerald_green"
            android:shadowRadius="6"
            android:shadowDx="0"
            android:shadowDy="0"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/hud_glass_card"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="8dp">

            <TextView
                style="@style/DocH2"
                android:textColor="@color/emerald_green"
                android:text="How it works" />

            <TextView
                style="@style/DocBody"
                android:textSize="13sp"
                android:text="1. Complete the 10-Point Calibration Walk (Setup menu).\n2. Auriga captures (distanceM, pixelWidth, pixelRow) anchor triplets at each station.\n3. Tap \'Submit Profile\' below to upload your anchors to the shared library.\n4. Future users with the same device model benefit immediately." />
        </LinearLayout>

        <Button
            android:id="@+id/btn_submit_calibration"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:minHeight="52dp"
            android:background="@drawable/drawer_item_accent_bg"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="⬡  Submit My Calibration Profile"
            android:textSize="14sp"
            android:textColor="@color/amber_text"
            android:fontFamily="sans-serif-medium"
            android:textAllCaps="false"
            android:letterSpacing="0.04"
            android:contentDescription="Submit your calibration walk anchors to the shared device library" />

        <!-- SDK / Partner Interest section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SDK &amp; PARTNER INTEREST"
            android:textSize="10sp"
            android:textColor="@color/emerald_green"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.22"
            android:textAllCaps="true"
            android:shadowColor="@color/emerald_green"
            android:shadowRadius="6"
            android:shadowDx="0"
            android:shadowDy="0"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/hud_glass_card"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="8dp">

            <TextView
                style="@style/DocH2"
                android:textColor="@color/emerald_green"
                android:text="Available integrations" />

            <TextView
                style="@style/DocBody"
                android:textSize="13sp"
                android:text="• AurigaAero SDK — drone &amp; robotics (ROS bridge)\n• AurigaIndustrial — warehouse forklift safety\n• AurigaSentinel — crowd &amp; fall detection node\n• White-label / OEM licensing for assistive tech" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/drawer_item_contribute_bg"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="◈  SDK Enquiries"
                android:textSize="14sp"
                android:textColor="@color/emerald_green"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="sdk@drakosanctis.com"
                android:textSize="13sp"
                android:textColor="@color/muted_label"
                android:fontFamily="monospace" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Include: platform, camera module specs (resolution, HFOV), and intended use case. Access token issued within 48 hours."
                android:textSize="12sp"
                android:textColor="@color/drawer_sub_text"
                android:fontFamily="sans-serif"
                android:lineSpacingMultiplier="1.3" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_sdk_interest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:minHeight="52dp"
            android:background="@drawable/drawer_item_contribute_bg"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="◈  Express SDK Interest via Feedback"
            android:textSize="14sp"
            android:textColor="@color/emerald_green"
            android:fontFamily="sans-serif-medium"
            android:textAllCaps="false"
            android:letterSpacing="0.04"
            android:contentDescription="Open the feedback form with SDK interest category pre-selected" />

        <!-- Open Source note -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/hud_glass_card"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⬡  OPEN ECOSYSTEM"
                android:textSize="10sp"
                android:textColor="@color/auriga_cyan"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.14"
                android:textAllCaps="true"
                android:layout_marginBottom="8dp" />

            <TextView
                style="@style/DocBody"
                android:textSize="12sp"
                android:text="Auriga\'s calibration library is crowd-sourced. The more profiles contributed, the more devices get sub-20 cm accuracy out of the box — zero calibration walk required for known hardware. Every profile helps a user who may never be able to run the walk themselves." />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
