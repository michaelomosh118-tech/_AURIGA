<?xml version="1.0" encoding="utf-8"?>
<!--
    Adaptive launcher icon. The background color (flavor_accent) is injected
    per product flavor via resValue in app/build.gradle, so each variant gets
    a distinctive tile in the launcher:
        navi       -> #00B8D4 cyan
        sentinel   -> #D50000 red
        aero       -> #2962FF blue
        industrial -> #FF6F00 orange
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@color/flavor_accent" />
    <foreground android:drawable="@drawable/ic_launcher_foreground" />
</adaptive-icon>
