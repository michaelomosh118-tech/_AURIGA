<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AurigaHUDTheme" parent="android:Theme.NoTitleBar.Fullscreen">
        <item name="android:windowBackground">@color/space_black</item>
        <item name="android:textColor">@color/hud_text</item>
    </style>

    <style name="HUDReadoutLarge">
        <item name="android:textSize">48sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/auriga_cyan</item>
        <item name="android:fontFamily">sans-serif-condensed</item>
    </style>

    <style name="HUDLabelSmall">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/cobalt_blue</item>
        <item name="android:textAllCaps">true</item>
    </style>
</resources>
