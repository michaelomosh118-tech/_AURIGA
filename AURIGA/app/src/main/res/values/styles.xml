<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        AurigaHUDTheme: full-bleed surface used by every camera-driven HUD
        (LocatorActivity, LocatorWebActivity, MainActivity).

        Parent must be a Theme.AppCompat descendant. Android 15 (API 35)
        tightened the launch-time theme resolution path so it now reads
        AppCompat attributes (windowActionBar, colorAccent, …) during
        performLaunchActivity, even for activities that extend plain
        android.app.Activity. Inheriting from android:Theme.NoTitleBar.*
        leaves those attributes undefined and crashes on launch with
        "You need to use a Theme.AppCompat theme (or descendant) with
        this activity." Theme.AppCompat.NoActionBar gives us those
        attributes for free; the four explicit window items below
        re-create the immersive fullscreen behaviour the previous
        framework-only theme had.
    -->
    <style name="AurigaHUDTheme" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@color/deep_space</item>
        <item name="android:textColor">@color/hud_text</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!--
        Android 15 (API 35) enforces explicit layout_width / layout_height
        on every View child of a ViewGroup; earlier Android versions
        silently defaulted to wrap_content when absent. Baking
        wrap_content into both HUD styles keeps every styled TextView
        valid without having to touch every callsite.
    -->
    <style name="HUDReadoutLarge">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">52sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/auriga_cyan</item>
        <item name="android:fontFamily">sans-serif-condensed</item>
        <item name="android:letterSpacing">0.04</item>
        <item name="android:shadowColor">@color/auriga_cyan</item>
        <item name="android:shadowDx">0</item>
        <item name="android:shadowDy">0</item>
        <item name="android:shadowRadius">14</item>
    </style>

    <style name="HUDReadoutMedium">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/hud_text</item>
        <item name="android:fontFamily">sans-serif-condensed</item>
        <item name="android:letterSpacing">0.06</item>
        <item name="android:shadowColor">@color/cyan_glow_30</item>
        <item name="android:shadowDx">0</item>
        <item name="android:shadowDy">0</item>
        <item name="android:shadowRadius">10</item>
    </style>

    <style name="HUDLabelSmall">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/muted_label</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.18</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="HUDLabelAccent" parent="HUDLabelSmall">
        <item name="android:textColor">@color/auriga_cyan</item>
    </style>

    <!-- Glass card container used for HUD readouts -->
    <style name="HUDGlassCard">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/hud_glass_card</item>
        <item name="android:padding">16dp</item>
        <item name="android:orientation">vertical</item>
    </style>

    <!-- Hamburger drawer row: full-width pill button with glass background. -->
    <style name="DrawerItem">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">6dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:gravity">start|center_vertical</item>
        <item name="android:paddingStart">14dp</item>
        <item name="android:paddingEnd">14dp</item>
        <item name="android:background">@drawable/drawer_item_bg</item>
        <item name="android:textColor">@color/drawer_item_text</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.04</item>
    </style>

    <!-- Drawer sub-description text under drawer item titles -->
    <style name="DrawerItemSub">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/drawer_sub_text</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:layout_marginTop">1dp</item>
    </style>

    <!-- Accent drawer row (Calibration Walk — amber) -->
    <style name="DrawerItemAccent" parent="DrawerItem">
        <item name="android:background">@drawable/drawer_item_accent_bg</item>
        <item name="android:textColor">@color/amber_text</item>
    </style>

    <!-- Support drawer row (cobalt blue) -->
    <style name="DrawerItemSupport" parent="DrawerItem">
        <item name="android:background">@drawable/drawer_item_support_bg</item>
        <item name="android:textColor">@color/auriga_cyan</item>
    </style>

    <!-- Contribute drawer row (emerald) -->
    <style name="DrawerItemContribute" parent="DrawerItem">
        <item name="android:background">@drawable/drawer_item_contribute_bg</item>
        <item name="android:textColor">@color/emerald_green</item>
    </style>

    <!--
        AurigaDocTheme: document/page surface for the drawer destinations
        (About, Help, Targets, Reader, CalibrationWalk, Feedback,
        Support, Contribute). Same indigo background as the HUD so
        the activities feel like extensions of the app, not system-
        default white sheets.

        Same Theme.AppCompat.NoActionBar reparenting as AurigaHUDTheme
        above; see that block's comment for the Android 15 launch-
        time theme resolution rationale. The four explicit window
        items keep the immersive fullscreen behaviour the previous
        framework-only parent theme had.
    -->
    <style name="AurigaDocTheme" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@color/deep_space</item>
        <item name="android:textColor">@color/hud_text</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="DocH1">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/auriga_cyan</item>
        <item name="android:fontFamily">sans-serif-condensed</item>
        <item name="android:letterSpacing">0.06</item>
        <item name="android:shadowColor">@color/auriga_cyan</item>
        <item name="android:shadowDx">0</item>
        <item name="android:shadowDy">0</item>
        <item name="android:shadowRadius">14</item>
    </style>

    <style name="DocH2">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">20dp</item>
        <item name="android:layout_marginBottom">6dp</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/auriga_cyan</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.18</item>
    </style>

    <style name="DocBody">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/hud_text</item>
        <item name="android:lineSpacingMultiplier">1.35</item>
    </style>
</resources>
