<?xml version="1.0" encoding="utf-8"?>
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Matches AurigaApplication.writeCrashFile which uses
         getExternalFilesDir(null)/crashes -->
    <external-files-path name="crashes" path="crashes/" />
    <!-- Fallback when external storage is unavailable -->
    <files-path name="crashes-internal" path="crashes/" />
</paths>
