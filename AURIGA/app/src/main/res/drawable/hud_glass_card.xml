<?xml version="1.0" encoding="utf-8"?>
<!--
    Glassmorphism card used for HUD readouts (distance / bearing / signature).
    A semi-opaque indigo fill sits behind a 1dp cyan stroke with rounded
    corners; on top of a live camera frame this reads as frosted glass
    without needing a real RenderEffect blur (which is API 31+).
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <gradient
                android:angle="135"
                android:startColor="@color/glass_panel_strong"
                android:endColor="@color/glass_panel" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <stroke android:width="1dp" android:color="@color/glass_stroke" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
</layer-list>
