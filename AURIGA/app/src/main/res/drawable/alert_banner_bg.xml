<?xml version="1.0" encoding="utf-8"?>
<!--
    Threat-alert banner. Uses a horizontal gradient and a thicker red
    stroke to sell urgency without resorting to flat colour fill.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="6dp" />
            <gradient
                android:angle="0"
                android:startColor="@color/alert_red_dark"
                android:endColor="@color/alert_red" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="6dp" />
            <stroke android:width="1dp" android:color="@color/alert_glow_30" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
</layer-list>
