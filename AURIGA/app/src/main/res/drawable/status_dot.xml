<?xml version="1.0" encoding="utf-8"?>
<!--
    Pulsing status indicator dot used in the top HUD. A cyan inner solid
    with a faint outer glow ring sells the "live telemetry" feel.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/cyan_glow_30" />
        </shape>
    </item>
    <item
        android:left="3dp"
        android:right="3dp"
        android:top="3dp"
        android:bottom="3dp">
        <shape android:shape="oval">
            <solid android:color="@color/status_online" />
        </shape>
    </item>
</layer-list>
