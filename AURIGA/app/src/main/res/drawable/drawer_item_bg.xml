<?xml version="1.0" encoding="utf-8"?>
<!--
    Drawer row background. Default = subtle glass card; pressed = brighter
    cyan tint; activated = filled cyan + dark text (used to mark the
    currently-open destination).
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_activated="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/auriga_cyan" />
            <corners android:radius="10dp" />
            <stroke android:width="1dp" android:color="@color/auriga_cyan" />
        </shape>
    </item>

    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#3300F0FF" />
            <corners android:radius="10dp" />
            <stroke android:width="1dp" android:color="@color/glass_stroke" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/glass_panel" />
            <corners android:radius="10dp" />
            <stroke android:width="1dp" android:color="@color/glass_stroke_dim" />
        </shape>
    </item>
</selector>
