<?xml version="1.0" encoding="utf-8"?>
<!-- Emerald-tinted pill for Contribute section rows -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#4000D06A" />
            <corners android:radius="10dp" />
            <stroke android:width="1dp" android:color="#9900D06A" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1200D06A" />
            <corners android:radius="10dp" />
            <stroke android:width="1dp" android:color="#2D00D06A" />
        </shape>
    </item>
</selector>
