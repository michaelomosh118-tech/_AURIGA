<?xml version="1.0" encoding="utf-8"?>
<!-- Amber-tinted pill for the 10-Point Calibration Walk row -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#60FFB300" />
            <corners android:radius="10dp" />
            <stroke android:width="1dp" android:color="#CCFFB300" />
        </shape>
    </item>
    <item android:state_activated="true">
        <shape android:shape="rectangle">
            <solid android:color="#40FFB300" />
            <corners android:radius="10dp" />
            <stroke android:width="1dp" android:color="#99FFB300" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#18FFB300" />
            <corners android:radius="10dp" />
            <stroke android:width="1dp" android:color="#44FFB300" />
        </shape>
    </item>
</selector>
