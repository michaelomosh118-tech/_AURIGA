<?xml version="1.0" encoding="utf-8"?>
<!-- Cyan hairline with a subtle centre glow — used between drawer sections -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0D00F0FF" />
            <size android:height="1dp" />
        </shape>
    </item>
    <item android:gravity="center_horizontal" android:width="80dp">
        <shape android:shape="rectangle">
            <solid android:color="#5500F0FF" />
            <size android:height="1dp" />
            <corners android:radius="1dp" />
        </shape>
    </item>
</layer-list>
