<?xml version="1.0" encoding="utf-8"?>
<!--
    Concentric radar rings with a soft inner glow. Three rings at 100%, 66%
    and 33% radius give the centre HUD the feel of a real targeting reticle
    instead of a single empty circle, and the radial gradient inside paints
    a subtle cyan haze that mimics phosphor bloom.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Inner phosphor glow -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="100"
                android:centerX="0.5"
                android:centerY="0.5"
                android:startColor="@color/cyan_glow_15"
                android:endColor="@android:color/transparent" />
        </shape>
    </item>

    <!-- Outer ring -->
    <item>
        <shape android:shape="oval">
            <stroke android:width="2dp" android:color="@color/auriga_cyan" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>

    <!-- Mid ring (66%) -->
    <item
        android:left="34dp"
        android:right="34dp"
        android:top="34dp"
        android:bottom="34dp">
        <shape android:shape="oval">
            <stroke android:width="1dp" android:color="@color/cyan_glow_30" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>

    <!-- Inner ring (33%) -->
    <item
        android:left="68dp"
        android:right="68dp"
        android:top="68dp"
        android:bottom="68dp">
        <shape android:shape="oval">
            <stroke android:width="1dp" android:color="@color/cyan_glow_30" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>

    <!-- Crosshair vertical -->
    <item
        android:left="99dp"
        android:right="99dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/cyan_glow_30" />
        </shape>
    </item>

    <!-- Crosshair horizontal -->
    <item
        android:top="99dp"
        android:bottom="99dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/cyan_glow_30" />
        </shape>
    </item>

    <!-- Centre dot -->
    <item
        android:left="94dp"
        android:right="94dp"
        android:top="94dp"
        android:bottom="94dp">
        <shape android:shape="oval">
            <solid android:color="@color/auriga_cyan" />
        </shape>
    </item>

</layer-list>
