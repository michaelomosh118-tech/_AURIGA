<?xml version="1.0" encoding="utf-8"?>
<!-- Cobalt-tinted pill for Support section rows -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#500057FF" />
            <corners android:radius="10dp" />
            <stroke android:width="1dp" android:color="#AA0057FF" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#180057FF" />
            <corners android:radius="10dp" />
            <stroke android:width="1dp" android:color="#330057FF" />
        </shape>
    </item>
</selector>
