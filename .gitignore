# Build output
**/build/
**/.gradle/
**/.kotlin/

# IDE
.idea/
*.iml
.vscode/

# Android local config (contains absolute SDK path)
local.properties

# OS noise
.DS_Store
Thumbs.db

# Archives / binary bundles that should not live in git
*.zip
*.zip.zip
*.apk
*.aab
*.jks
*.keystore

# ...but keep the stable debug keystore committed so every CI / local build
# signs debug APKs with the same key, preventing "App not installed" failures
# caused by signature mismatch between successive builds.
!AURIGA/keystore/debug.keystore

# Logs
*.log
node_modules
