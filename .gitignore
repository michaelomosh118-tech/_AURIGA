# Build output
**/build/
**/.gradle/
**/.kotlin/

# IDE
.idea/
*.iml
.vscode/

# Android local config (contains absolute SDK path)
local.properties

# OS noise
.DS_Store
Thumbs.db

# Archives / binary bundles that should not live in git
*.zip
*.zip.zip
*.apk
*.aab
*.jks
*.keystore

# ...but keep the stable debug keystore committed so every CI / local build
# signs debug APKs with the same key, preventing "App not installed" failures
# caused by signature mismatch between successive builds.
!AURIGA/keystore/debug.keystore

# Phase 1 native YOLOv8n locator: the TFLite model is large (~6-12 MB)
# and not source-controlled. CI / local builds drop it into
# AURIGA/app/src/main/assets/ before assembling the APK -- see
# AURIGA/app/src/main/assets/MODEL_README.md for provenance.
*.tflite

# Logs
*.log
node_modules
